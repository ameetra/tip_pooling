generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma-pg"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SHIFT_LEAD
  EMPLOYEE
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  role         String
  isActive     Boolean  @default(true)
  mustChangePassword Boolean @default(false)
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@map("users")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  logoUrl   String?
  address   String?
  timezone  String   @default("America/Los_Angeles")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  employees          Employee[]
  supportStaffConfig SupportStaffConfig[]
  tipEntries         TipEntry[]

  @@map("tenants")
}

model Employee {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  email      String
  role       String
  hourlyRate Float
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant          Tenant                @relation(fields: [tenantId], references: [id])
  tipCalculations TipCalculation[]
  rateHistory     EmployeeRateHistory[]
  roleRates       EmployeeRoleRate[]

  @@unique([tenantId, email])
  @@index([tenantId, isActive])
  @@map("employees")
}

// Current base rate per (employee, role). An employee can work multiple roles at different rates.
model EmployeeRoleRate {
  id         String   @id @default(cuid())
  employeeId String
  role       String
  hourlyRate Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, role])
  @@map("employee_role_rates")
}

model SupportStaffConfig {
  id            String   @id @default(cuid())
  tenantId      String
  role          String
  percentage    Float
  effectiveDate DateTime @default(now())
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, role])
  @@map("support_staff_config")
}

model TipEntry {
  id              String    @id @default(cuid())
  tenantId        String
  entryDate       String
  cashInRegister  Float     @default(0)
  cashSales       Float     @default(0)
  cashTips        Float     @default(0)
  posTips         Float     @default(0)
  startingDrawer  Float?
  closingDrawer   Float?
  electronicTips  Float     @default(0)
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  replacedById    String?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  tipCalculations TipCalculation[]

  @@index([tenantId, entryDate, isDeleted])
  @@map("tip_entries")
}

model TipCalculation {
  id                    String @id @default(cuid())
  tipEntryId            String
  employeeId            String
  roleOnDay             String
  totalHours            Float
  hourlyPay             Float
  baseTips              Float
  supportTipsGiven      Float  @default(0)
  supportTipsReceived   Float  @default(0)
  finalTips             Float
  totalPay              Float
  effectiveHourlyRate   Float
  snapshotHourlyRate    Float  @default(0)
  snapshotSupportPct    Float  @default(0)

  tipEntry         TipEntry          @relation(fields: [tipEntryId], references: [id])
  employee         Employee          @relation(fields: [employeeId], references: [id])

  @@index([tipEntryId])
  @@map("tip_calculations")
}

model EmployeeRateHistory {
  id            String   @id @default(cuid())
  employeeId    String
  role          String   @default("SERVER")
  hourlyRate    Float
  effectiveDate String
  createdAt     DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("employee_rate_history")
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  entityType String
  entityId   String
  action     String
  oldValues  String?
  newValues  String?
  createdAt  DateTime @default(now())

  @@index([tenantId, entityType])
  @@index([entityId])
  @@map("audit_logs")
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  tenantId  String?
  token     String    @unique
  expiresAt DateTime
  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  ipAddress String?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([ipAddress])
  @@map("magic_link_tokens")
}
